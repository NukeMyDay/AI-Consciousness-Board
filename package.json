{
	"name": "ai-consciousness-board",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"seed": "npx tsx src/lib/server/db/seed.ts",
		"seed:paths": "npx tsx src/lib/server/db/seed-paths.ts",
		"seed:feeds": "npx tsx src/lib/server/db/seed-feeds.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.80.0",
		"@google/genai": "^1.46.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"better-sqlite3": "^12.8.0",
		"drizzle-orm": "^0.45.2",
		"nanoid": "^5.1.7",
		"rss-parser": "^3.13.0",
		"svelte-dnd-action": "^0.9.69"
	}
}
